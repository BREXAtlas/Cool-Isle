# Server-side/automation secrets. Never expose these through browser JavaScript.
MET_OFFICE_API_KEY=
YOUTUBE_API_KEY=
X_BEARER_TOKEN=
# Actions supplies github.token automatically. A local value should be a
# short-lived token with Contents write permission, used only for integration tests.
WEATHERCHART_QUOTA_TOKEN=

# Optional runtime and deployment configuration.
WEATHER_PROXY_URL=
WEATHERCHART_CANONICAL_URL=https://weatherchart.uk/
WEATHERCHART_TARGET_REPO=BREXAtlas/WeatherChart-UK
WEATHERCHART_DEPLOY_TOKEN=

# The 350-attempt UTC-day maximum, twelve-location batch size, and 55-minute
# freshness window are hard-coded safety invariants, not environment overrides.
